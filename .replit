modules = ["python-3.10"]
run = "python app.py"

[packager]
language = "python"

[nix]

[agent]
expertMode = true

[[ports]]
localPort = 5000

[[ports]]
localPort = 8501
externalPort = 80

[[ports]]
localPort = 8502

[[ports]]
localPort = 8503

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python app.py"
waitForPort = 5000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "pip install -r requirements.txt && gunicorn --bind=0.0.0.0:8080 app:app"]
